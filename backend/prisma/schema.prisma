generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  SALES
  SHIPPING
}

enum OrderStatus {
  DRAFT
  PARTIALLY_PAID
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum OrderPaymentMethod {
  WIRE_TRANSFER
  CREDIT_CARD
}

enum ShipmentStatus {
  PENDING
  IN_TRANSIT
  DELIVERED
  DELAYED
  CANCELLED
}

enum NoteEntityType {
  ORDER
  SHIPMENT
}

enum LeadStatus {
  PROSPECT
  CALL_BACK_LATER
  NOT_INTERESTED
  NEEDS_LOCALLY
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  name         String   @db.VarChar(120)
  email        String   @unique @db.VarChar(160)
  passwordHash String   @db.VarChar(255)
  role         Role     @default(SALES)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  leads  Lead[]
  orders Order[]
  notes  Note[]
  notifications Notification[]
}

model Lead {
  id               String    @id @default(uuid()) @db.Uuid
  leadDate         DateTime
  adviserName      String    @db.VarChar(120)
  cmpt             String    @db.VarChar(80)
  customerPhone    String    @db.VarChar(30)
  customerName     String    @db.VarChar(160)
  partDescription  String    @db.VarChar(255)
  quote            Decimal?  @db.Decimal(12, 2)
  comments         String?   @db.Text
  prospects        String    @db.VarChar(255)
  status           LeadStatus @default(PROSPECT)
  createdById      String    @db.Uuid
  convertedOrderId String?   @unique @db.Uuid
  convertedAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  createdBy      User   @relation(fields: [createdById], references: [id], onDelete: Restrict)
  convertedOrder Order? @relation("ConvertedLeadOrder", fields: [convertedOrderId], references: [id], onDelete: SetNull)

  @@index([leadDate])
  @@index([createdById])
  @@index([status])
  @@index([convertedAt])
}

model Order {
  id              String      @id @default(uuid()) @db.Uuid
  orderNumber     String      @unique @db.VarChar(50)
  customerName    String      @db.VarChar(160)
  partDescription String      @db.VarChar(255)
  customerEmail   String?     @db.VarChar(160)
  customerPhone   String?     @db.VarChar(30)
  intakeDetails   Json?
  price           Decimal     @db.Decimal(12, 2)
  quantity        Int
  totalSaleAmount Decimal     @db.Decimal(12, 2)
  status          OrderStatus @default(DRAFT)
  paymentMethod   OrderPaymentMethod?
  createdById     String      @db.Uuid
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  createdBy User       @relation(fields: [createdById], references: [id], onDelete: Restrict)
  sourceLead Lead?     @relation("ConvertedLeadOrder")
  shipments Shipment[]
  notes     Note[]
  invoice   Invoice?

  @@index([orderNumber])
  @@index([createdById])
}

model Invoice {
  id                     String    @id @default(uuid()) @db.Uuid
  orderId                String    @unique @db.Uuid
  invoiceNumber          String    @unique @db.VarChar(50)
  invoiceDate            DateTime
  salesAssistant         String?   @db.VarChar(120)
  customerName           String    @db.VarChar(160)
  contactNumber          String?   @db.VarChar(30)
  billingAddress         String?   @db.Text
  shippingAddress        String?   @db.Text
  shippingVendor         String    @default("LTL") @db.VarChar(80)
  deliveryTimeline       String    @default("7-8 Business Days") @db.VarChar(120)
  itemDescription        String    @db.VarChar(255)
  vehiclePartDescription String?   @db.VarChar(255)
  quantity               Int
  saleAmount             Decimal   @db.Decimal(12, 2)
  paymentStatus          String?   @db.VarChar(80)
  paymentDate            DateTime?
  paymentSource          String?   @db.VarChar(160)
  shippingCost           Decimal   @default(0) @db.Decimal(12, 2)
  salesTaxes             Decimal   @default(0) @db.Decimal(12, 2)
  coreCharge             Decimal   @default(0) @db.Decimal(12, 2)
  totalAmount            Decimal   @db.Decimal(12, 2)
  customerSignature      String?   @db.Text
  customerSignatureImage String?   @db.Text
  signatureDate          DateTime?
  signedAt               DateTime?
  signatureIpAddress     String?   @db.VarChar(64)
  signatureTokenHash     String?   @unique @db.VarChar(128)
  signatureTokenExpiresAt DateTime?
  signatureRequestedAt   DateTime?
  signatureLastSentAt    DateTime?
  status                 String    @default("CREATED") @db.VarChar(40)
  pdfStorageKey          String?   @db.VarChar(255)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Restrict)

  @@index([invoiceNumber])
  @@index([createdAt])
  @@index([signatureTokenExpiresAt])
}

model Shipment {
  id          String         @id @default(uuid()) @db.Uuid
  bolNumber   String         @unique @db.VarChar(50)
  proNumber   String?        @unique @db.VarChar(50)
  carrierName String?        @db.VarChar(120)
  status      ShipmentStatus @default(PENDING)
  orderId     String         @db.Uuid
  shippedAt   DateTime?
  deliveredAt DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  order   Order           @relation(fields: [orderId], references: [id], onDelete: Restrict)
  costs   ShipmentCost[]
  events  ShipmentEvent[]
  notes   Note[]

  @@index([bolNumber])
  @@index([proNumber])
  @@index([orderId])
}

model ShipmentCost {
  id               String   @id @default(uuid()) @db.Uuid
  shipmentId       String   @unique @db.Uuid
  purchaseAmount   Decimal  @db.Decimal(12, 2)
  shippingAmount   Decimal  @default(0) @db.Decimal(12, 2)
  additionalAmount Decimal  @default(0) @db.Decimal(12, 2)
  grossProfit      Decimal  @db.Decimal(12, 2)
  currency         String   @default("USD") @db.VarChar(10)
  notes            String?  @db.Text
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Restrict)

  @@index([shipmentId])
}

model ShipmentEvent {
  id          String   @id @default(uuid()) @db.Uuid
  shipmentId  String   @db.Uuid
  eventType   String   @db.VarChar(80)
  description String?  @db.Text
  location    String?  @db.VarChar(160)
  eventAt     DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Restrict)

  @@index([shipmentId])
  @@index([eventAt])
}

model Note {
  id         String         @id @default(uuid()) @db.Uuid
  content    String         @db.Text
  entityType NoteEntityType
  authorId   String         @db.Uuid
  orderId    String?        @db.Uuid
  shipmentId String?        @db.Uuid
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  author   User      @relation(fields: [authorId], references: [id], onDelete: Restrict)
  order    Order?    @relation(fields: [orderId], references: [id], onDelete: Restrict)
  shipment Shipment? @relation(fields: [shipmentId], references: [id], onDelete: Restrict)

  @@index([authorId])
  @@index([orderId])
  @@index([shipmentId])
  @@index([entityType, orderId])
  @@index([entityType, shipmentId])
}

model Notification {
  id              String    @id @default(uuid()) @db.Uuid
  recipientUserId String    @db.Uuid
  type            String    @db.VarChar(80)
  title           String    @db.VarChar(160)
  message         String    @db.Text
  entityType      String    @db.VarChar(40)
  entityId        String    @db.Uuid
  isRead          Boolean   @default(false)
  readAt          DateTime?
  clearedAt       DateTime?
  createdAt       DateTime  @default(now())

  recipient User @relation(fields: [recipientUserId], references: [id], onDelete: Cascade)

  @@index([recipientUserId, clearedAt, createdAt])
  @@index([recipientUserId, isRead, clearedAt])
  @@index([entityType, entityId])
}
